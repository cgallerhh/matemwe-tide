# Copy this file to .env for local testing (never commit .env!)
# In GitHub Actions these are set as Repository Secrets.

# Your Gmail address (the one that SENDS the daily email)
GMAIL_USER=your.address@gmail.com

# Gmail App Password (NOT your normal password)
# Create at: https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be enabled)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Where the daily digest should be delivered (can be the same as GMAIL_USER)
RECIPIENT_EMAIL=christian.galler@gmail.de

# Anthropic API key for AI-powered job scoring (optional but recommended)
# Get yours at: https://console.anthropic.com/settings/keys
# Without this key the system falls back to keyword-based scoring.
ANTHROPIC_API_KEY=sk-ant-...
